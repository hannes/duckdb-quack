# name: test/sql/attach_ctas.test
# description: test CREATE TABLE AS over rpc attach
# group: [sql]

require quack

require httpfs

set ignore_error_messages __none__

foreach server 'quack:localhost'


statement ok
set rpc_default_token='asdf'


statement ok con1
call quack_serve({server});

statement ok con2
attach {server} as rpc

statement ok
create table rpc.t as select range a from range(10);

query I
from rpc.t select count(a);
----
10

statement ok
drop table rpc.t;

statement ok con2
detach rpc;

statement ok con1
call rpc_stop({server});

endloop
