# name: test/sql/attach_ctas.test
# description: test CREATE TABLE AS over rpc attach
# group: [sql]

require quack

foreach server 'quack:localhost'

foreach ssl false true

statement ok con1
call rpc_start({server}, disable_ssl={ssl});

statement ok con2
attach {server} as rpc (disable_ssl {ssl})

statement ok
create table rpc.t as select range a from range(10);

query I
from rpc.t select count(a);
----
10

statement ok
drop table rpc.t;

statement ok con2
detach rpc;

statement ok con1
call rpc_stop({server});

endloop

endloop
