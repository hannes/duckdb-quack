# name: test/sql/uri.test
# description: test rpc extension
# group: [sql]

require rpc

query IIIII
select unnest(rpc_uri_parser('remote:localhost', true));
----
localhost	1294	false	true	https://localhost:1294

query IIIII
select unnest(rpc_uri_parser('remote:localhost', false));
----
localhost	1294	false	false	http://localhost:1294

query IIIII
select unnest(rpc_uri_parser('remote://localhost', true));
----
localhost	1294	false	true	https://localhost:1294

query IIIII
select unnest(rpc_uri_parser('remote:localhost:1234', true));
----
localhost	1234	false	true	https://localhost:1234

query IIIII
select unnest(rpc_uri_parser('remote:otherhost', true));
----
otherhost	1294	false	true	https://otherhost:1294

query IIIII
select unnest(rpc_uri_parser('remote:127.0.0.1', true));
----
127.0.0.1	1294	false	true	https://127.0.0.1:1294

query IIIII
select unnest(rpc_uri_parser('remote:127.0.0.1:1234', true));
----
127.0.0.1	1234	false	true	https://127.0.0.1:1234

query IIIII
select unnest(rpc_uri_parser('remote:[::1]', true));
----
::1	1294	true	true	https://[::1]:1294

query IIIII
select unnest(rpc_uri_parser('remote:[::1]:1234', true));
----
::1	1234	true	true	https://[::1]:1234


#failure cases

statement error
select unnest(rpc_uri_parser('', true));
----
Invalid DuckDB remote URI


statement error
select unnest(rpc_uri_parser('asdf', true));
----
Invalid DuckDB remote URI

statement error
select unnest(rpc_uri_parser('remote:', true));
----
Missing hostname


statement error
select unnest(rpc_uri_parser('remote::', true));
----
Invalid Port


statement error
select unnest(rpc_uri_parser('remote:localhost:', true));
----
Invalid Port


statement error
select unnest(rpc_uri_parser('remote:localhost:asdf', true));
----
Invalid Port


statement error
select unnest(rpc_uri_parser('remote:[::1', true));
----
Invalid IPv6 URL
