# name: test/sql/uri.test
# description: test rpc extension
# group: [sql]

require quack

require httpfs

query IIIII
select unnest(quack_uri_parser('quack:localhost', true));
----
localhost	1294	false	true	https://localhost:1294

query IIIII
select unnest(quack_uri_parser('quack:localhost', false));
----
localhost	1294	false	false	http://localhost:1294

query IIIII
select unnest(quack_uri_parser('quack://localhost', true));
----
localhost	1294	false	true	https://localhost:1294

query IIIII
select unnest(quack_uri_parser('quack:localhost:1234', true));
----
localhost	1234	false	true	https://localhost:1234

query IIIII
select unnest(quack_uri_parser('quack:otherhost', true));
----
otherhost	1294	false	true	https://otherhost:1294

query IIIII
select unnest(quack_uri_parser('quack:127.0.0.1', true));
----
127.0.0.1	1294	false	true	https://127.0.0.1:1294

query IIIII
select unnest(quack_uri_parser('quack:127.0.0.1:1234', true));
----
127.0.0.1	1234	false	true	https://127.0.0.1:1234

query IIIII
select unnest(quack_uri_parser('quack:[::1]', true));
----
::1	1294	true	true	https://[::1]:1294

query IIIII
select unnest(quack_uri_parser('quack:[::1]:1234', true));
----
::1	1234	true	true	https://[::1]:1234


#failure cases

statement error
select unnest(quack_uri_parser('', true));
----
Invalid DuckDB Quack RPC URI


statement error
select unnest(quack_uri_parser('asdf', true));
----
Invalid DuckDB Quack RPC URI

statement error
select unnest(quack_uri_parser('quack:', true));
----
Missing hostname


statement error
select unnest(quack_uri_parser('quack::', true));
----
Invalid Port


statement error
select unnest(quack_uri_parser('quack:localhost:', true));
----
Invalid Port


statement error
select unnest(quack_uri_parser('quack:localhost:asdf', true));
----
Invalid Port


statement error
select unnest(quack_uri_parser('quack:[::1', true));
----
Invalid IPv6 URL
