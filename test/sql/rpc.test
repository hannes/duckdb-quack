# name: test/sql/rpc.test
# description: test rpc extension
# group: [sql]

require rpc

require json

statement ok
call rpc_generate_keys();

foreach server  '{TEST_DIR}/duckdb-rpc-socket' 'https://localhost:8080' 'http://localhost:8081'

statement ok con1
call rpc_start({server});


sleep 1000 millisecond

query I con2
from rpc_call({server}, 'select 42')
----
42

statement error con2
from rpc_call({server}, '')
----
Error


statement error con2
from rpc_call({server}, 'selexxxct 42')
----
Error

query I con2
select max(range) from rpc_call({server}, 'from range(100000)')
----
99999

statement ok con2
from rpc_call({server}, 'from test_all_types()')


statement ok con2
from rpc_call({server}, 'create table fuu(i integer)')

statement ok con2
from rpc_call({server}, 'insert into fuu values (42)')

query I ok con2
from rpc_call({server}, 'from fuu')
----
42

statement ok con2
from rpc_call({server}, 'drop table fuu')

# some error cases
statement error con2
from rpc_call({server}, NULL)
----
cannot be NULL

statement error con2
from rpc_call(NULL, '')
----
cannot be NULL

statement error con1
call rpc_start()
----
Binder Error

statement error con1
call rpc_start('')
----
Invalid listen string

statement error con1
call rpc_start(NULL)
----
Invalid listen string


statement ok con2
from rpc_call({server}, 'select 42')


# this very involved method makes sure we get some cardinalities
statement ok con1
create table my_range as from range(4242)

statement ok con2
set enable_profiling='json'

statement ok con2
set profiling_output='{TEST_DIR}/profile_cardinality_1.json'

statement ok con2
from rpc_call({server}, 'from my_range')

statement ok con2
set enable_profiling='no_output'

query I con2
from read_json('{TEST_DIR}/profile_cardinality_1.json') select children[1].extra_info."Estimated Cardinality"::INT ec
----
4242

statement ok con2
set enable_profiling='json'

statement ok con2
set profiling_output='{TEST_DIR}/profile_cardinality_2.json'

statement ok con2
from rpc_call({server}, 'from my_range limit 2121')

statement ok con2
set enable_profiling='no_output'

query I con2
from read_json('{TEST_DIR}/profile_cardinality_2.json') select children[1].extra_info."Estimated Cardinality"::INT ec
----
2121

statement ok con1
drop table my_range
# end involved method


statement ok con 1
call rpc_stop({server})

statement ok con 1
call rpc_stop({server})


statement error con2
from rpc_call({server}, 'select 42')
----
IO Error

endloop
