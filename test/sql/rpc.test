# name: test/sql/rpc.test
# description: test rpc extension
# group: [sql]

require rpc

foreach server '__TEST_DIR__/duckdb-rpc-socket' 'wss://localhost:4243'

statement ok con1
select rpc_start(${server});


sleep 100 millisecond

query I con2
from rpc_call(${server}, 'select 42')
----
42

statement error con2
from rpc_call(${server}, '')
----
Error


statement error con2
from rpc_call(${server}, 'selexxxct 42')
----
Error

query I con2
select max(range) from rpc_call(${server}, 'from range(100000)')
----
99999


statement ok con2
from test_all_types() -- haha

# some error cases
statement error con2
from rpc_call(${server}, NULL)
----
cannot be NULL

statement error con2
from rpc_call(NULL, '')
----
cannot be NULL

statement error con1
select rpc_start()
----
Binder Error

statement error con1
select rpc_start('')
----
Invalid listen string

statement error con1
select rpc_start(NULL)
----
Invalid listen string

endloop
