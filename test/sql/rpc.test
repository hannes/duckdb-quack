# name: test/sql/rpc.test
# description: test rpc extension
# group: [sql]

require rpc

statement ok
call rpc_generate_keys();

foreach server 'wss://localhost:4243' '__TEST_DIR__/duckdb-rpc-socket'

statement ok con1
call rpc_start(${server});


sleep 100 millisecond

query I con2
from rpc_call(${server}, 'select 42')
----
42

statement error con2
from rpc_call(${server}, '')
----
Error


statement error con2
from rpc_call(${server}, 'selexxxct 42')
----
Error

query I con2
select max(range) from rpc_call(${server}, 'from range(100000)')
----
99999


statement ok con2
from rpc_call(${server}, 'from test_all_types()')


statement ok con2
from rpc_call(${server}, 'create table fuu(i integer)')

statement ok con2
from rpc_call(${server}, 'insert into fuu values (42)')

query I ok con2
from rpc_call(${server}, 'from fuu')
----
42

statement ok con2
from rpc_call(${server}, 'drop table fuu')


# some error cases
statement error con2
from rpc_call(${server}, NULL)
----
cannot be NULL

statement error con2
from rpc_call(NULL, '')
----
cannot be NULL

statement error con1
call rpc_start()
----
Binder Error

statement error con1
call rpc_start('')
----
Invalid listen string

statement error con1
call rpc_start(NULL)
----
Invalid listen string


statement ok con2
from rpc_call(${server}, 'select 42')

statement ok con 1
call rpc_stop(${server})

statement ok con 1
call rpc_stop(${server})


statement error con2
from rpc_call(${server}, 'select 42')
----
IO Error

endloop
