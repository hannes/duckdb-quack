# name: test/sql/rpc.test
# description: test rpc extension
# group: [sql]

require quack

require json

set ignore_error_messages __none__

foreach server 'quack:localhost'

foreach ssl true


statement ok con1
call rpc_start({server}, disable_ssl={ssl});


sleep 100 millisecond


query I con2
from rpc_call({server}, 'select 42', disable_ssl={ssl})
----
42

#
# statement error con2
# from rpc_call({server}, 'select 42', disable_ssl=(NOT {ssl}))
# ----
# xxxx

statement error con2
from rpc_call({server}, '', disable_ssl={ssl})
----
Error


statement error con2
from rpc_call({server}, 'selexxxct 42', disable_ssl={ssl})
----
Error

query I con2
select max(range) from rpc_call({server}, 'from range(100000)', disable_ssl={ssl})
----
99999

statement ok con2
from rpc_call({server}, 'from test_all_types()', disable_ssl={ssl})


statement ok con2
from rpc_call({server}, 'create table fuu(i integer)', disable_ssl={ssl})

statement ok con2
from rpc_call({server}, 'insert into fuu values (42)', disable_ssl={ssl})

query I ok con2
from rpc_call({server}, 'from fuu', disable_ssl={ssl})
----
42

statement error con2
from rpc_call({server}, 'from yyyy', disable_ssl={ssl})
----
does not exist

statement ok con2
from rpc_call({server}, 'drop table fuu', disable_ssl={ssl})

# some error cases
statement error con2
from rpc_call({server}, NULL, disable_ssl={ssl})
----
cannot be NULL

statement error con2
from rpc_call(NULL, '', disable_ssl={ssl})
----
cannot be NULL

statement error con1
call rpc_start()
----
Binder Error

statement error con1
call rpc_start('')
----
Invalid listen string

statement error con1
call rpc_start(NULL)
----
Invalid listen string


statement ok con2
from rpc_call({server}, 'select 42', disable_ssl={ssl})


# this very involved method makes sure we get some cardinalities
statement ok con1
create table my_range as from range(4242)

statement ok con2
set enable_profiling='json'

statement ok con2
set profiling_output='{TEST_DIR}/profile_cardinality_1.json'

statement ok con2
from rpc_call({server}, 'from my_range', disable_ssl={ssl})

statement ok con2
set enable_profiling='no_output'

query I con2
from read_json('{TEST_DIR}/profile_cardinality_1.json') select children[1].extra_info."Estimated Cardinality"::INT ec
----
4242

statement ok con2
set enable_profiling='json'

statement ok con2
set profiling_output='{TEST_DIR}/profile_cardinality_2.json'

statement ok con2
from rpc_call({server}, 'from my_range limit 2121', disable_ssl={ssl})

statement ok con2
set enable_profiling='no_output'

query I con2
from read_json('{TEST_DIR}/profile_cardinality_2.json') select children[1].extra_info."Estimated Cardinality"::INT ec
----
2121

statement ok con1
drop table my_range
# end involved method


statement ok con 1
call rpc_stop({server})

statement ok con 1
call rpc_stop({server})


statement error con2
from rpc_call({server}, 'select 42', disable_ssl={ssl})
----
IO Error

endloop

endloop
