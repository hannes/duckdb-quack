# name: test/sql/rpc.test
# description: test rpc extension
# group: [sql]

# Require statement will ensure this test is run with this extension loaded
require rpc

statement ok con1
select start_rpc_server(4242);

query I con2
from call_rpc_server('wss://localhost:4242', 'select 42')
----
42

query I con2
from call_rpc_server('wss://localhost:4242', 'select max(range) from range(10000)')
----
9999

statement ok con2
from call_rpc_server('wss://localhost:4242', 'from test_all_types()')
