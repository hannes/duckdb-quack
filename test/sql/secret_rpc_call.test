# name: test/sql/secret_rpc_call.test
# description: verify quack_query(uri, sql) picks up auth token from quack secrets
# group: [sql]

require quack

require httpfs

# Server-side
statement ok con1
set rpc_default_token='s3kr3t'

statement ok con1
call quack_serve('quack:localhost:20102');

sleep 100 millisecond

# --- 1. Matching secret: quack_query succeeds with the secret's token ---

statement ok con2
create secret rpc_ok (type quack, token 's3kr3t', scope 'quack:localhost:20102')

query II con2
from quack_query('quack:localhost:20102', 'select 1, 2')
----
1	2

statement ok con2
drop secret rpc_ok

# --- 2. Wrong secret: quack_query fails with Authentication failed ---

statement ok con2
create secret rpc_bad (type quack, token 'nope', scope 'quack:localhost:20102')

statement error con2
from quack_query('quack:localhost:20102', 'select 1')
----
Authentication failed

statement ok con2
drop secret rpc_bad

# --- 3. No secret: falls back to rpc_default_token on the client ---

statement ok con2
set rpc_default_token='s3kr3t'

query I con2
from quack_query('quack:localhost:20102', 'select 7')
----
7

statement ok con1
call rpc_stop('quack:localhost:20102')
