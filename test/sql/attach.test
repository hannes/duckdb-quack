# name: test/sql/attach.test
# description: test rpc extension
# group: [sql]

require quack

require httpfs

set ignore_error_messages __none__

statement ok
create schema moo;

statement ok
create table fuu as values(42, 43);

statement ok
create table moo.fuu2 as values(44, 45);

foreach server 'quack:localhost'


statement ok con1
call quack_serve({server}, token='asdf');

query II con2
from quack_query({server}, 'select 42, 43', token='asdf')
----
42	43

# we can attach with a straight token
statement ok con2
attach {server} as rpc2 (token 'asdf')

statement ok con2
detach rpc2;

statement ok con2
create secret (type quack, token 'asdf')

statement ok con2
attach {server} as rpc


query II
from rpc.fuu;
----
42	43

query I
from rpc.query('select 42');
----
42

query I
from rpc.main.fuu select col1 where col0=42 ;
----
43

query II
from rpc.main.fuu where col0=43;
----

statement error
from rpc.yyyy
----
Table with name yyyy does not exist

statement error
from rpc.xxx.yyy;
----
schema "xxx" does not exist

# TODO
# query II
# from rpc.moo.fuu2;
# ----
# 42	43
#
#
# statement ok
# create schema rpc.fuuschema;

statement ok
begin transaction


statement ok
create table rpc.fuu2(i integer);


statement ok
from rpc.fuu2;

statement ok
commit

statement ok
from rpc.fuu2;


statement ok
drop table rpc.fuu2;


statement ok
begin transaction

statement ok
create table rpc.fuu3(i integer);

statement error
insert into rpc.fuu2 values (42);
----
not exist

statement ok
insert into rpc.fuu3 from range(10000);

query I
from rpc.fuu3 select count(i);
----
10000

statement ok
rollback

statement error
from rpc.fuu3;
----
not exist


statement ok con2
detach rpc;

statement error con2
detach rpc;
----
database not found

statement ok con1
call quack_stop({server});

statement error con2
attach {server} as rpc
----

endloop
